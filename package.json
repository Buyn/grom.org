{
  "scripts": {
      "deps": "yarn install",
      "watch": "shadow-cljs watch app;",
      "release": "shadow-cljs release app;",
      "server": "shadow-cljs server;",
      "clean": "rm -rf target; rm -rf public/js/compiled",
      "build-gh": "rm -rf docs && npx shadow-cljs release app && mkdir -p docs && cp -r public/* docs && touch docs/.nojekyll",
      "css": "tailwindcss -i ./src/css/main.css -o ./public/css/style.css --watch"

  },
  "dependencies": {
    "create-react-class": "^15.6.2",
    "react": "^16.0.0",
    "react-dom": "^16.0.0",
    "shadow-cljs": "^2.0.80"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19"
  }
}
